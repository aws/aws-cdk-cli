{
  "//": "TypeScript config for the web explorer SPA. Bundled by esbuild, not by the package's CommonJS/Node tsc build. Used for editor IntelliSense and the bundler's typecheck pass.",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["react", "react-dom"]
  },
  "include": ["frontend"]
}
